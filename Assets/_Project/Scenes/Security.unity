  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: c9fbada51d00d1f489fffb6060c02b91, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::SceneDialogueStarter
  dialogueId: 51
  description: "\u041D\u0435\u0431\u043E\u043B\u044C\u0448\u0430\u044F \u043A\u043E\u043C\u043D\u0430\u0442\u043A\u0430
    \u043F\u0440\u0438 \u0432\u0445\u043E\u0434\u0435 \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442.
    \u0412 \u043D\u0435\u0439 \u0441\u0442\u043E\u044F\u0442 \u0441\u0442\u0443\u043B,
    \u0441\u0442\u043E\u043B \u0438 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043C\u043E\u043D\u0438\u0442\u043E\u0440\u043E\u0432. \u041D\u0430 \u0441\u0442\u043E\u043B\u0435
    \u2014 \u043A\u0440\u0443\u0436\u043A\u0430 \u0441 \u043E\u0441\u0442\u044B\u0432\u0448\u0438\u043C
    \u0447\u0430\u0435\u043C, \u0440\u0430\u0437\u0432\u0451\u0440\u043D\u0443\u0442\u044B\u0439
    \u0431\u0443\u0442\u0435\u0440\u0431\u0440\u043E\u0434, \u0440\u0430\u0441\u043A\u0440\u044B\u0442\u044B\u0439
    \u0436\u0443\u0440\u043D\u0430\u043B \u0434\u0435\u0436\u0443\u0440\u0441\u0442\u0432.
    \u041D\u0430 \u0441\u0442\u0435\u043D\u0435 \u0432\u0438\u0441\u0438\u0442 \u0447\u0451\u0440\u043D\u044B\u0439
    \u0434\u0438\u0441\u043A\u043E\u0432\u044B\u0439 \u0442\u0435\u043B\u0435\u0444\u043E\u043D. "
  autoStartDialogue: 1
  startDelay: 3
